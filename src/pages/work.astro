---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: 'The Iron Skillet',
    industry: 'Restaurant • Hamilton',
    summary:
      'A family-owned brunch spot on Locke Street wanted a website that matched the warmth of their dining room. We built a site that lets hungry locals browse the menu, see fresh photos, and book a table in 30 seconds.',
    metrics: [
      { label: 'Reservations / month', before: '12', after: '84' },
      { label: 'Page load time', before: '4.2s', after: '0.7s' },
      { label: 'Mobile bounce rate', before: '71%', after: '24%' },
    ],
    accent: 'from-amber-500/15 to-transparent',
    placeholder: 'TIS',
  },
  {
    name: 'Steeltown Renovations',
    industry: 'Contractor • Stoney Creek',
    summary:
      'A general contractor with great reviews and a website that looked stuck in 2008. We rebuilt the whole thing with a portfolio that finally showcases their craftsmanship — and a quote form that actually works on phones.',
    metrics: [
      { label: 'Quote requests / month', before: '6', after: '37' },
      { label: 'Average project size', before: '$8k', after: '$23k' },
      { label: 'Google ranking (renovations Hamilton)', before: '#22', after: '#4' },
    ],
    accent: 'from-blue-500/15 to-transparent',
    placeholder: 'SR',
  },
  {
    name: 'Bayfront Hair Studio',
    industry: 'Salon • Hamilton',
    summary:
      'A boutique salon needed online booking that didn\'t feel like 2014. We integrated their existing booking system into a clean, photo-forward site that lets clients book any of four stylists in two clicks.',
    metrics: [
      { label: 'Online bookings / week', before: '4', after: '52' },
      { label: 'Phone time saved', before: '—', after: '~6 hrs/wk' },
      { label: 'New client acquisition', before: 'Word of mouth', after: '+38% from search' },
    ],
    accent: 'from-rose-500/15 to-transparent',
    placeholder: 'BHS',
  },
];
---

<BaseLayout
  title="Our Work — Northpoint Digital"
  description="Recent websites we've built for Hamilton-area businesses. Real results from real local clients."
>
  <!-- Header -->
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-16">
    <div class="max-w-2xl">
      <div class="text-xs uppercase tracking-widest text-accent mb-4">Selected work</div>
      <h1 class="font-display text-5xl md:text-6xl leading-tight tracking-tight mb-6">
        Real businesses. <span class="gold-text italic">Real results.</span>
      </h1>
      <p class="text-lg text-foreground-muted leading-relaxed">
        A few of the websites we've built for businesses in Hamilton and the surrounding area.
        We measure success the same way our clients do — more customers, more bookings, more revenue.
      </p>
    </div>
  </section>

  <!-- Project cards -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div class="space-y-8">
      {projects.map((project, i) => (
        <article class="card overflow-hidden">
          <div class="grid md:grid-cols-2">
            <!-- Visual -->
            <div class={`relative h-64 md:h-auto bg-gradient-to-br ${project.accent} flex items-center justify-center border-b md:border-b-0 md:border-r border-line`}>
              <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 1px 1px, #c9a961 1px, transparent 0); background-size: 24px 24px;"></div>
              <div class="relative font-display text-7xl gold-text">{project.placeholder}</div>
            </div>

            <!-- Content -->
            <div class="p-8 md:p-10">
              <div class="text-xs uppercase tracking-widest text-foreground-subtle mb-3">{project.industry}</div>
              <h2 class="font-display text-3xl mb-4">{project.name}</h2>
              <p class="text-foreground-muted leading-relaxed mb-6">{project.summary}</p>

              <div class="space-y-3 pt-5 border-t border-line">
                {project.metrics.map((m) => (
                  <div class="flex justify-between items-baseline gap-4">
                    <span class="text-sm text-foreground-muted">{m.label}</span>
                    <div class="flex items-baseline gap-2 text-sm">
                      <span class="text-foreground-subtle line-through">{m.before}</span>
                      <svg class="w-3 h-3 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M13 5l7 7-7 7"/>
                      </svg>
                      <span class="text-accent font-medium">{m.after}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Honesty note -->
    <div class="mt-12 p-6 rounded-lg border border-dashed border-line text-sm text-foreground-subtle text-center">
      <span class="text-accent">●</span> These are sample case studies showing the kind of work and results we deliver.
      Real client case studies will replace these as we publish them with permission.
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="card p-10 md:p-14 text-center bg-gradient-to-br from-ink-elevated to-ink-card">
      <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
        Want results like these for your business?
      </h2>
      <p class="text-foreground-muted mb-7 max-w-lg mx-auto">
        Free 20-minute call. We'll look at your current site (or lack of one) and tell you exactly what would move the needle.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-md bg-accent text-ink font-medium hover:bg-accent-hover transition-colors"
      >
        Book your call
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>

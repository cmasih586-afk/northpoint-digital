---
import BaseLayout from '../layouts/BaseLayout.astro';

const concepts = [
  {
    industry: 'Restaurants & cafés',
    locale: 'Hamilton, Ontario',
    summary:
      "From brunch spots on Locke Street to family pizzerias in Stoney Creek — sites that turn hungry locals into bookings, not just visitors.",
    features: [
      'Photo-forward menu pages',
      'Online reservations or waitlist signup',
      'Hours, address, and directions front-and-center',
      'Mobile-first — most diners search from their phone',
    ],
    accent: 'from-amber-500/15 to-transparent',
    placeholder: 'R',
  },
  {
    industry: 'Contractors & home services',
    locale: 'Hamilton, Ontario',
    summary:
      "General contractors, renovators, plumbers, electricians, landscapers — the trades that build Hamilton. Sites designed to win bigger jobs.",
    features: [
      'Portfolio gallery showcasing past work',
      'Quote request forms that work on phones',
      'Trust signals — license, insurance, reviews',
      'Service area maps for SEO',
    ],
    accent: 'from-blue-500/15 to-transparent',
    placeholder: 'C',
  },
  {
    industry: 'Salons & wellness',
    locale: 'Hamilton, Ontario',
    summary:
      "Hair, nails, massage, fitness, beauty — businesses where clients book regular appointments and bring their friends.",
    features: [
      'Online booking integrated with your existing tool',
      'Stylist or staff profiles',
      'Service & pricing menu',
      'Photo galleries for portfolio work',
    ],
    accent: 'from-rose-500/15 to-transparent',
    placeholder: 'S',
  },
];
---

<BaseLayout
  title="Our Work — Northpoint Digital"
  description="Design concepts and the kinds of websites we build for Hamilton-area small businesses."
>
  <!-- Header -->
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-12">
    <div class="max-w-2xl">
      <div class="text-xs uppercase tracking-widest text-accent mb-4">Our work</div>
      <h1 class="font-display text-5xl md:text-6xl leading-tight tracking-tight mb-6">
        Design concepts. <span class="gold-text italic">Built for Hamilton.</span>
      </h1>
      <p class="text-lg text-foreground-muted leading-relaxed">
        Northpoint is a new studio. While we're building our first client portfolio,
        here's a look at the kinds of websites we design for local businesses — and
        what each industry actually needs from a site.
      </p>
    </div>
  </section>

  <!-- Hamilton Launch banner — high in the page so it's seen -->
  <section class="max-w-6xl mx-auto px-6 pb-12">
    <div class="card p-7 md:p-8 relative overflow-hidden border-accent/40 bg-gradient-to-r from-accent-soft to-transparent">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-5">
        <div>
          <div class="inline-flex items-center gap-2 px-2.5 py-1 mb-3 rounded-full border border-accent/40 bg-ink-elevated text-xs text-accent">
            <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
            Hamilton Local Launch
          </div>
          <h2 class="font-display text-2xl md:text-3xl tracking-tight">
            Be our flagship case study — <span class="gold-text">3 spots open.</span>
          </h2>
          <p class="text-foreground-muted text-sm mt-2">
            25% off setup • first month free • 6-month commitment at standard rate
          </p>
        </div>
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-md bg-accent text-ink font-medium hover:bg-accent-hover transition-colors whitespace-nowrap"
        >
          Claim a spot
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Industry concepts -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div class="mb-10 max-w-2xl">
      <div class="text-xs uppercase tracking-widest text-accent mb-3">Industries we design for</div>
      <h2 class="font-display text-3xl md:text-4xl tracking-tight">
        Every industry needs different things from a website.
      </h2>
    </div>

    <div class="space-y-6">
      {concepts.map((concept) => (
        <article class="card overflow-hidden">
          <div class="grid md:grid-cols-5">
            <!-- Visual -->
            <div class={`relative h-56 md:h-auto md:col-span-2 bg-gradient-to-br ${concept.accent} flex items-center justify-center border-b md:border-b-0 md:border-r border-line`}>
              <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 1px 1px, #c9a961 1px, transparent 0); background-size: 24px 24px;"></div>
              <div class="relative font-display text-8xl gold-text">{concept.placeholder}</div>
            </div>

            <!-- Content -->
            <div class="p-8 md:p-10 md:col-span-3">
              <div class="text-xs uppercase tracking-widest text-foreground-subtle mb-3">{concept.locale}</div>
              <h3 class="font-display text-3xl mb-4">{concept.industry}</h3>
              <p class="text-foreground-muted leading-relaxed mb-6">{concept.summary}</p>

              <div class="pt-5 border-t border-line">
                <div class="text-xs uppercase tracking-widest text-foreground-subtle mb-3">What we build</div>
                <ul class="space-y-2.5">
                  {concept.features.map((f) => (
                    <li class="flex gap-2.5 text-sm">
                      <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 6L9 17l-5-5"/>
                      </svg>
                      <span class="text-foreground-muted">{f}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <p class="text-center text-foreground-subtle text-sm mt-10 max-w-xl mx-auto">
      Don't see your industry? We work with shops, clinics, gyms, studios, and any small
      business that needs a real online presence. <a href="/contact" class="text-accent hover:underline">Tell us about yours</a>.
    </p>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="card p-10 md:p-14 text-center bg-gradient-to-br from-ink-elevated to-ink-card">
      <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">
        Ready to build something real?
      </h2>
      <p class="text-foreground-muted mb-7 max-w-lg mx-auto">
        Free 20-minute call. We'll look at your business, your competitors, and recommend
        exactly what would work — even if that's "you don't need us yet."
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-md bg-accent text-ink font-medium hover:bg-accent-hover transition-colors"
      >
        Book your call
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>

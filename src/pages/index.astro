---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    title: 'Custom websites',
    description: 'Hand-built, fast-loading sites that look professional and convert visitors into customers.',
    icon: 'M3 7h18M3 12h18M3 17h12',
  },
  {
    title: 'Hosting & care',
    description: 'Lightning-fast hosting, daily backups, security updates — included in every monthly plan.',
    icon: 'M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z',
  },
  {
    title: 'Ongoing updates',
    description: 'Need a new menu, photo, or page? Send us a message — we make the change, usually same day.',
    icon: 'M12 5v14M5 12h14',
  },
];

const tiers = [
  {
    name: 'Starter',
    setup: 300,
    monthly: 79,
    tagline: 'For small businesses getting online for the first time.',
    features: [
      '3-page custom website',
      'Mobile-responsive design',
      'Hosting + SSL included',
      '1 update request per month',
      'Email support',
    ],
    featured: false,
  },
  {
    name: 'Standard',
    setup: 600,
    monthly: 149,
    tagline: 'Most popular. For growing businesses ready to compete.',
    features: [
      '5–7 page custom website',
      'Contact form + Google Maps',
      'Hosting + SSL + daily backups',
      '3 update requests per month',
      'Basic SEO setup',
      'Priority email support',
    ],
    featured: true,
  },
  {
    name: 'Premium',
    setup: 1200,
    monthly: 249,
    tagline: 'For established businesses that want a competitive edge.',
    features: [
      '10+ page custom website',
      'Blog or news section',
      'Advanced SEO + Google Business setup',
      'Hosting + SSL + daily backups',
      'Unlimited small updates',
      'Phone + email support',
    ],
    featured: false,
  },
];

const process = [
  {
    n: '01',
    title: 'Quick discovery call',
    body: 'A free 20-minute call. We learn about your business, your customers, and what you need the site to do.',
  },
  {
    n: '02',
    title: 'Design & build',
    body: 'We send you a draft within 5–7 days. You give feedback. We refine until it feels right.',
  },
  {
    n: '03',
    title: 'Launch',
    body: 'We handle the technical setup — domain, hosting, email — so you can focus on running your business.',
  },
  {
    n: '04',
    title: 'Ongoing care',
    body: 'Need a change? Send us a message. Most updates are live within 24 hours.',
  },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative max-w-6xl mx-auto px-6 pt-24 pb-20 md:pt-32 md:pb-28">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 px-3 py-1 mb-8 rounded-full border border-line bg-ink-elevated text-xs text-foreground-muted">
        <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
        A web studio in Hamilton, Ontario
      </div>

      <h1 class="font-display text-5xl md:text-7xl leading-[1.05] tracking-tight mb-6">
        Premium websites for
        <span class="gold-text italic">Hamilton</span>
        businesses.
      </h1>

      <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-2xl mb-10">
        We design, build, and maintain fast, modern websites for restaurants, contractors,
        salons, and shops across Hamilton and the surrounding area. One flat monthly fee,
        no surprises.
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-md bg-accent text-ink font-medium hover:bg-accent-hover transition-colors"
        >
          Book a free 20-min call
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href="/work"
          class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-md border border-line-strong text-foreground hover:bg-ink-elevated transition-colors"
        >
          See our work
        </a>
      </div>

      <div class="mt-12 flex items-center gap-6 text-xs text-foreground-subtle">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
          No long-term contracts
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
          You own your site
        </div>
        <div class="hidden sm:flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
          Cancel anytime
        </div>
      </div>
    </div>
  </section>

  <!-- Services strip -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-3 gap-5">
      {services.map((service) => (
        <div class="card p-7">
          <div class="w-10 h-10 rounded-md bg-accent-soft flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={service.icon}/>
            </svg>
          </div>
          <h3 class="font-display text-xl mb-2">{service.title}</h3>
          <p class="text-foreground-muted text-sm leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Why us -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div>
        <div class="text-xs uppercase tracking-widest text-accent mb-4">Why Northpoint</div>
        <h2 class="font-display text-4xl md:text-5xl tracking-tight mb-6 leading-tight">
          A real partner, not a faceless template service.
        </h2>
        <p class="text-foreground-muted text-lg leading-relaxed">
          Most "website builders" leave you to figure things out alone. We don't.
          Every Northpoint client gets a real human in Hamilton who knows your site,
          your business, and your goals.
        </p>
      </div>
      <div class="space-y-6">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-md bg-accent-soft flex items-center justify-center text-accent font-display">1</div>
          <div>
            <h4 class="font-medium mb-1">Local. Actually local.</h4>
            <p class="text-foreground-muted text-sm leading-relaxed">Based in Hamilton. We'll meet you for coffee on King Street if that's what it takes.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-md bg-accent-soft flex items-center justify-center text-accent font-display">2</div>
          <div>
            <h4 class="font-medium mb-1">No template farms.</h4>
            <p class="text-foreground-muted text-sm leading-relaxed">Every site is built to fit the business. Yours won't look like anyone else's.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-md bg-accent-soft flex items-center justify-center text-accent font-display">3</div>
          <div>
            <h4 class="font-medium mb-1">You own everything.</h4>
            <p class="text-foreground-muted text-sm leading-relaxed">Your domain, your content, your code. Walk away whenever you want — no hostage situations.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-md bg-accent-soft flex items-center justify-center text-accent font-display">4</div>
          <div>
            <h4 class="font-medium mb-1">Fast. Like, really fast.</h4>
            <p class="text-foreground-muted text-sm leading-relaxed">Our sites load in under a second. Google ranks fast sites higher. Your customers stay longer.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="text-center mb-14">
      <div class="text-xs uppercase tracking-widest text-accent mb-4">Pricing</div>
      <h2 class="font-display text-4xl md:text-5xl tracking-tight mb-4">
        Simple, honest pricing.
      </h2>
      <p class="text-foreground-muted text-lg max-w-2xl mx-auto">
        One setup fee. One flat monthly fee. Cancel anytime. No surprise invoices.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      {tiers.map((tier) => (
        <div
          class:list={[
            'card p-8 relative',
            tier.featured && 'border-accent/40 bg-gradient-to-b from-accent-soft to-transparent',
          ]}
        >
          {tier.featured && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full bg-accent text-ink text-xs font-semibold">
              Most popular
            </div>
          )}
          <h3 class="font-display text-2xl mb-1">{tier.name}</h3>
          <p class="text-sm text-foreground-muted mb-6 min-h-[2.5rem]">{tier.tagline}</p>
          <div class="mb-6">
            <div class="flex items-baseline gap-1">
              <span class="font-display text-4xl">${tier.monthly}</span>
              <span class="text-foreground-muted">/mo</span>
            </div>
            <p class="text-xs text-foreground-subtle mt-1">+ ${tier.setup} one-time setup</p>
          </div>
          <ul class="space-y-3 mb-8">
            {tier.features.map((f) => (
              <li class="flex gap-2.5 text-sm">
                <svg class="w-4 h-4 text-accent flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                <span class="text-foreground-muted">{f}</span>
              </li>
            ))}
          </ul>
          <a
            href="/contact"
            class:list={[
              'block w-full text-center py-2.5 rounded-md text-sm font-medium transition-colors',
              tier.featured
                ? 'bg-accent text-ink hover:bg-accent-hover'
                : 'border border-line-strong text-foreground hover:bg-ink-elevated',
            ]}
          >
            Get started
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Process -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="mb-14 max-w-2xl">
      <div class="text-xs uppercase tracking-widest text-accent mb-4">How it works</div>
      <h2 class="font-display text-4xl md:text-5xl tracking-tight mb-4">
        Live in two weeks. Sometimes one.
      </h2>
    </div>

    <div class="grid md:grid-cols-4 gap-5">
      {process.map((step) => (
        <div class="card p-6">
          <div class="font-display text-3xl gold-text mb-3">{step.n}</div>
          <h4 class="font-medium mb-2">{step.title}</h4>
          <p class="text-sm text-foreground-muted leading-relaxed">{step.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Final CTA -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="card p-10 md:p-16 text-center bg-gradient-to-br from-ink-elevated to-ink-card">
      <h2 class="font-display text-3xl md:text-5xl tracking-tight mb-5 max-w-2xl mx-auto">
        Ready to get a website your business deserves?
      </h2>
      <p class="text-foreground-muted text-lg mb-8 max-w-xl mx-auto">
        Free 20-minute call. No pressure, no slide deck. Just a real conversation
        about what would work for you.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-md bg-accent text-ink font-medium hover:bg-accent-hover transition-colors"
      >
        Book your free call
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>

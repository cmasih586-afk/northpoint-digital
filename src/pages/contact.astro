---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceArea = [
  'Hamilton',
  'Burlington',
  'Stoney Creek',
  'Ancaster',
  'Dundas',
  'Waterdown',
  'Grimsby',
  'Oakville',
];
---

<BaseLayout
  title="Contact — Northpoint Digital"
  description="Get in touch with Northpoint Digital. Free 20-minute consultation for Hamilton-area businesses."
>
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-16">
    <div class="max-w-2xl mb-12">
      <div class="text-xs uppercase tracking-widest text-accent mb-4">Contact</div>
      <h1 class="font-display text-5xl md:text-6xl leading-tight tracking-tight mb-6">
        Let's talk about your <span class="gold-text italic">website.</span>
      </h1>
      <p class="text-lg text-foreground-muted leading-relaxed">
        Free 20-minute call. No slide decks, no pressure. We'll talk through what you need
        and recommend a plan — even if that plan is "you're fine, save your money."
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-5">
      <!-- Email card -->
      <a
        href="mailto:hello@northpointdigital.work"
        class="card p-7 hover:border-accent/50 transition-colors group"
      >
        <div class="w-10 h-10 rounded-md bg-accent-soft flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <path d="M22 6l-10 7L2 6"/>
          </svg>
        </div>
        <h3 class="font-display text-xl mb-1">Email us</h3>
        <p class="text-sm text-foreground-muted mb-3">Best for detailed questions or sharing your existing site. Replies usually within 1 business day.</p>
        <span class="text-accent text-sm font-medium group-hover:underline">hello@northpointdigital.work</span>
      </a>

      <!-- Book card -->
      <a
        href="#book"
        class="card p-7 hover:border-accent/50 transition-colors group bg-gradient-to-b from-accent-soft to-transparent border-accent/30"
      >
        <div class="w-10 h-10 rounded-md bg-accent-soft flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <h3 class="font-display text-xl mb-1">Book a free call</h3>
        <p class="text-sm text-foreground-muted mb-3">20-minute intro call over Zoom or phone — your choice. Pick any open slot.</p>
        <span class="text-accent text-sm font-medium group-hover:underline">See available times ↓</span>
      </a>
    </div>
  </section>

  <!-- Booking embed placeholder -->
  <section id="book" class="max-w-4xl mx-auto px-6 py-12">
    <div class="card p-8 md:p-12 text-center">
      <h2 class="font-display text-3xl tracking-tight mb-3">Pick a time</h2>
      <p class="text-foreground-muted mb-8 max-w-xl mx-auto">
        Free 20-minute introduction call over Zoom or phone — your choice.
      </p>

      <!-- Cal.com embed will go here once configured -->
      <div class="rounded-lg border border-dashed border-line p-12 bg-ink-elevated">
        <div class="text-foreground-subtle text-sm mb-4">📅 Booking calendar embed</div>
        <p class="text-foreground-muted text-sm mb-6 max-w-md mx-auto">
          We'll add your Cal.com or Calendly embed here once you sign up for one.
          Until then, email or call to book.
        </p>
        <a
          href="mailto:hello@northpointdigital.work?subject=Free%20consultation%20request"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md bg-accent text-ink font-medium hover:bg-accent-hover transition-colors"
        >
          Email to book a call
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Service area -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <div class="text-center mb-8">
      <div class="text-xs uppercase tracking-widest text-accent mb-3">Service area</div>
      <h2 class="font-display text-3xl tracking-tight mb-3">We serve businesses across Greater Hamilton.</h2>
      <p class="text-foreground-muted">In another city? Reach out anyway — we work remotely too.</p>
    </div>
    <div class="flex flex-wrap justify-center gap-2">
      {serviceArea.map((city) => (
        <span class="px-4 py-2 rounded-full border border-line bg-ink-elevated text-sm text-foreground-muted">
          {city}
        </span>
      ))}
    </div>
  </section>
</BaseLayout>
